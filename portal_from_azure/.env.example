# ============================================================
# Resource Portal – environment configuration
# Copy to .env and fill in values before starting.
# ============================================================

# Required in production – generate with:
#   openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Listen address (default: all interfaces, port 8000)
BIND=0.0.0.0:8000

# SQLite database path (relative to project root or absolute)
DATABASE_URL=portal.db

# Rust tracing log level: error | warn | info | debug | trace
RUST_LOG=info

# Directory where rotated log files are written
LOG_DIR=logs

# Parallel Cargo compile jobs (default: nproc)
# CARGO_BUILD_JOBS=4

# Path to the report paths TOML config file (default: ./report_paths.toml)
# REPORT_PATHS_FILE=/absolute/path/to/report_paths.toml

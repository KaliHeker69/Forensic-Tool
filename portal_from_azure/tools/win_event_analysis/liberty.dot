digraph ProcessExecution {
  rankdir=LR;
  graph [fontname="Segoe UI", bgcolor="#0d1117", pad=0.35, ranksep=1.2, nodesep=0.45, overlap=false, splines=curved, concentrate=true];
  node [shape=box, style="rounded,filled", fontname="Segoe UI", color="#1f6feb", fillcolor="#13233c", fontcolor="#c9d1d9", margin="0.18,0.12"];
  edge [fontname="Segoe UI", color="#3fb950", fontcolor="#8b949e", arrowsize=0.8];
  "smss.exe" [width="2.70", height="0.45", penwidth="2.80", fillcolor="#1c2128", color="#8b949e", fontcolor="#c9d1d9", tooltip="smss.exe (system): 11 executions"];
  "Unknown" [width="2.55", height="0.45", penwidth="2.64", fillcolor="#1c2128", color="#8b949e", fontcolor="#c9d1d9", tooltip="Unknown (system): 10 executions"];
  "Registry" [width="2.55", height="0.45", penwidth="2.64", fillcolor="#1c2128", color="#8b949e", fontcolor="#c9d1d9", tooltip="Registry (system): 10 executions"];
  "autochk.exe" [width="2.55", height="0.45", penwidth="2.64", fillcolor="#13233c", color="#58a6ff", fontcolor="#a5d6ff", tooltip="autochk.exe (normal): 10 executions"];
  "setupcl.exe" [width="1.25", height="0.45", penwidth="1.16", fillcolor="#13233c", color="#58a6ff", fontcolor="#a5d6ff", tooltip="setupcl.exe (normal): 1 executions"];
  "smss.exe" -> "autochk.exe" [label="10", penwidth="5.00", weight="10", color="#484f58", tooltip="smss.exe → autochk.exe: 10 executions"];
  "Unknown" -> "Registry" [label="10", penwidth="5.00", weight="10", color="#484f58", tooltip="Unknown → Registry: 10 executions"];
  "smss.exe" -> "setupcl.exe" [label="1", penwidth="1.40", weight="1", color="#484f58", tooltip="smss.exe → setupcl.exe: 1 executions"];
}
